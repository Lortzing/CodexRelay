<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.codex-relay.auto</string>
  <key>ProgramArguments</key>
  <array>
    <string>/ABSOLUTE/PATH/TO/codex-relay</string>
    <string>auto</string>
    <string>official</string>
    <string>backup</string>
    <string>--watch</string>
    <string>--interval</string>
    <string>60</string>
    <string>--fail-threshold</string>
    <string>2</string>
    <string>--recover-threshold</string>
    <string>2</string>
    <string>--cooldown</string>
    <string>300</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/codex-relay.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/codex-relay.err.log</string>
</dict>
</plist>
